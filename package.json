{
  "name": "iobroker.automatic-pond-aeration",
  "version": "0.0.15",
  "description": "Controls and monitors a pond aeration system: switches valves at up to 8 aeration points by schedule, cyclic round-robin or groups, with a pump safety interlock, optional oxygen/temperature/pressure monitoring, astro times and geolocation.",
  "author": {
    "name": "ssbingo",
    "email": "s.sternitzke@online.de"
  },
  "contributors": [],
  "homepage": "https://github.com/ssbingo/ioBroker.automatic-pond-aeration",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "pond",
    "aeration",
    "Teich",
    "Belüftung",
    "valve",
    "oxygen",
    "Koi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssbingo/ioBroker.automatic-pond-aeration.git"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "suncalc": "^2.0.0"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/adapter-react-v5": "^8.2.13",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@mui/x-date-pickers": "^7.29.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/iobroker": "npm:@iobroker/types@^7.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.20.0",
    "dayjs": "^1.11.21",
    "leaflet": "^1.9.4",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "admin/build/*.js",
    "doc/",
    "lib/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "prebuild": "rimraf admin/build",
    "build": "build-adapter react",
    "watch": "build-adapter react --watch",
    "prebuild:react": "rimraf admin/build",
    "build:react": "build-adapter react",
    "watch:react": "build-adapter react --watch",
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server"
  },
  "bugs": {
    "url": "https://github.com/ssbingo/ioBroker.automatic-pond-aeration/issues"
  },
  "readmeFilename": "README.md"
}
